# TODO(owner): transactional e-mail provider
MAIL_PROVIDER_API_KEY=replace_me
MAIL_FROM=no-reply@vendaforca.com

# TODO(owner): Web push VAPID keys
NEXT_PUBLIC_VAPID_PUBLIC_KEY=replace_me
